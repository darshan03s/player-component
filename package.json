{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "rm:next": "rm -rf .next",
    "predev": "pnpm rm:next",
    "predev:min": "pnpm rm:next",
    "prebuild": "pnpm rm:next",
    "dev": "next dev",
    "dev:min": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,html,mjs}": "prettier --write",
    "*.{ts,tsx,js,jsx}": "eslint --fix"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "mediabunny": "^1.50.6",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
